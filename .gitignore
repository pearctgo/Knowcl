# ============================================================
# .gitignore — 沈阳街区能耗预测项目
# 规则: 代码入库，数据/权重/环境 绝不入库
# ============================================================

# ── 数据目录（DATA_ROOT 下的所有内容）──────────────────────
data/
999-输出成果文件/
**/01-预处理中间件/
**/02-Stage1预训练权重/
**/03-Stage2下游结果/
**/04-可视化/
**/05-最终对比表/

# ── 模型权重 ───────────────────────────────────────────────
*.pt
*.pth
*.ckpt
*.bin
*.safetensors
*.npz
*.npy
*.pkl

# ── 环境变量（含真实路径，绝不入库）───────────────────────
.env

# ── Python 虚拟环境 ────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── IDE ────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.vs/

# ── 系统文件 ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── 日志 / 实验追踪 ────────────────────────────────────────
*.log
logs/
wandb/
mlruns/
runs/
tensorboard/
lightning_logs/

# ── Jupyter ────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── 临时文件 ───────────────────────────────────────────────
*.tmp
*.bak
*.orig

# ══════════════════════════════════════════════════════════
# 白名单例外（上面规则排除后，这些明确保留入库）
# ══════════════════════════════════════════════════════════
!results/experiments.csv
!configs/**/*.yaml
!config/**/*.yaml
!.env.example
!scripts/setup.sh
!scripts/setup.bat
