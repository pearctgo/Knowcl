# ============================================================
# .env.example — 复制为 .env 后填入本机实际路径
# ⚠️  .env 已在 .gitignore 中，绝不会被提交到 Git
# ============================================================

# Windows 示例（用正斜杠，避免转义问题）:
#   DATA_ROOT=G:/Knowcl
# Linux / Mac 示例:
#   DATA_ROOT=/data/knowcl

DATA_ROOT=G:/Knowcl
